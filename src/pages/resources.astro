---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resources | Serkan Haytac">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-zinc-50 tracking-tight">Resources</h1>
    <p class="text-zinc-400 mt-4 leading-relaxed">
      Some useful resources I keep forgetting about.
    </p>

    <ul class="mt-8 space-y-4">
      <li>
        <a href="http://www.pixelbeat.org/cmdline.html" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">
          List of Linux commands
        </a>
      </li>
      <li>
        <a href="https://github.com/git-tips/tips" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">
          Comprehensive list of GitHub commands
        </a>
      </li>
      <li>
        <a href="https://astralapp.com/" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">
          A web app to organize GitHub stars
        </a>
      </li>
      <li>
        <a href="https://github.com/Leo-G/DevopsWiki" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">
          A wiki of DevOps Tools, Tutorials and Scripts
        </a>
      </li>
      <li>
        <a href="https://www.datascienceatthecommandline.com/chapter-2-getting-started.html" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">
          Data Science with Command Line
        </a>
      </li>
      <li>
        <a href="https://wizardforcel.gitbooks.io/sicp-in-python/content/" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">
          SICP in Python
        </a>
      </li>
      <li>
        <a href="https://github.com/kay-is/react-from-zero/blob/master/02-jsx.html" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">
          React from Zero
        </a>
      </li>
    </ul>
  </div>
</BaseLayout>
