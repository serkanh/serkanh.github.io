---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookOpen from '@lucide/astro/icons/book-open';
import Star from '@lucide/astro/icons/star';
import Tablet from '@lucide/astro/icons/tablet-smartphone';

import booksData from '../data/books.json';

interface Book {
  title: string;
  author: string;
  book_id: string;
  isbn: string | null;
  cover: string;
  num_pages: number | null;
  user_rating: number;
  average_rating: number;
  date_added: string | null;
  date_read: string | null;
  book_published: string | null;
  link: string;
  shelf: string;
}

const allBooks: Book[] = booksData as Book[];

const currentlyReading = allBooks.filter((b) => b.shelf === 'currently-reading');
const read = allBooks
  .filter((b) => b.shelf === 'read')
  .sort((a, b) => {
    // Sort by date_added descending (most recently added first)
    const da = a.date_added ? new Date(a.date_added).getTime() : 0;
    const db = b.date_added ? new Date(b.date_added).getTime() : 0;
    return db - da;
  });
const currentIds = new Set(currentlyReading.map((b) => b.book_id));
const readIds = new Set(read.map((b) => b.book_id));
const wantToRead = allBooks.filter((b) => b.shelf === 'want-to-read' && !currentIds.has(b.book_id) && !readIds.has(b.book_id));

const totalPages = read.reduce((sum, b) => sum + (b.num_pages || 0), 0);
const ratedBooks = read.filter((b) => b.user_rating > 0);
const avgRating = ratedBooks.length > 0
  ? (ratedBooks.reduce((sum, b) => sum + b.user_rating, 0) / ratedBooks.length).toFixed(1)
  : '—';

function formatPages(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return n.toLocaleString();
}
---

<BaseLayout title="Reading | Serkan Haytac">
  <div class="flex">
    <!-- Sidebar -->
    <aside class="hidden lg:block w-56 shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto border-r border-zinc-800 px-6 py-10">
      <!-- Stats -->
      <p class="text-[11px] font-semibold text-zinc-500 uppercase tracking-widest mb-4">Stats</p>
      <div class="space-y-3 mb-8">
        <div class="flex items-center justify-between">
          <span class="text-[13px] text-zinc-400">Books read</span>
          <span class="text-[13px] text-zinc-200 font-mono">{read.length}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-[13px] text-zinc-400">Pages read</span>
          <span class="text-[13px] text-zinc-200 font-mono">{formatPages(totalPages)}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-[13px] text-zinc-400">Avg rating</span>
          <span class="text-[13px] text-zinc-200 font-mono">{avgRating}/5</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-[13px] text-zinc-400">Reading now</span>
          <span class="text-[13px] text-zinc-200 font-mono">{currentlyReading.length}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-[13px] text-zinc-400">Want to read</span>
          <span class="text-[13px] text-zinc-200 font-mono">{wantToRead.length}</span>
        </div>
      </div>

      <!-- Shelf nav -->
      <p class="text-[11px] font-semibold text-zinc-500 uppercase tracking-widest mb-3">Shelves</p>
      <nav class="space-y-1">
        <a href="#currently-reading" class="flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-400 hover:text-zinc-50 hover:bg-zinc-800/50 transition-colors">
          <span class="font-medium">Currently Reading</span>
          <span class="text-[11px] text-zinc-600 font-mono">{currentlyReading.length}</span>
        </a>
        <a href="#read" class="flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-400 hover:text-zinc-50 hover:bg-zinc-800/50 transition-colors">
          <span class="font-medium">Read</span>
          <span class="text-[11px] text-zinc-600 font-mono">{read.length}</span>
        </a>
        <a href="#want-to-read" class="flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-400 hover:text-zinc-50 hover:bg-zinc-800/50 transition-colors">
          <span class="font-medium">Want to Read</span>
          <span class="text-[11px] text-zinc-600 font-mono">{wantToRead.length}</span>
        </a>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="flex-1 min-w-0 px-8 lg:px-12 pt-12 pb-16">
      <h1 class="text-3xl font-bold text-zinc-50 tracking-tight" data-animate="fade-up">
        <span class="inline-flex items-center gap-3">
          <BookOpen class="w-8 h-8" />
          Reading
        </span>
      </h1>
      <p class="text-zinc-500 text-sm mt-2 flex items-center gap-1.5" data-animate="fade-up" data-delay="0.1">
        <Tablet class="w-3.5 h-3.5" />
        Kindle reads — doesn't include physical books.
      </p>

      <!-- Search -->
      <div class="mt-6 mb-10" data-animate="fade-up" data-delay="0.15">
        <input
          id="book-search"
          type="text"
          placeholder="Filter books..."
          class="w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-50 placeholder-zinc-600 outline-none focus:border-zinc-600 transition-colors"
        />
      </div>

      <!-- Currently Reading -->
      <section id="currently-reading" class="mb-14 book-section">
        <div class="flex items-baseline gap-3 mb-5 sticky top-14 bg-[#09090B] py-2 z-10 border-b border-zinc-800 pb-3">
          <h2 class="text-2xl font-bold text-zinc-50">Currently Reading</h2>
          <span class="text-[12px] text-zinc-600 font-mono">{currentlyReading.length} books</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-5">
          {currentlyReading.map((book) => (
            <a
              href={book.link}
              target="_blank"
              rel="noopener noreferrer"
              class="book-card group block"
              data-title={book.title.toLowerCase()}
              data-author={book.author.toLowerCase()}
            >
              <div class="aspect-[2/3] rounded-md overflow-hidden bg-zinc-800 mb-2 shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300">
                {book.cover ? (
                  <img src={book.cover} alt={book.title} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-zinc-600 text-xs px-2 text-center">{book.title}</div>
                )}
              </div>
              <p class="text-[12px] font-medium text-zinc-300 leading-tight line-clamp-2 group-hover:text-blue-400 transition-colors">{book.title}</p>
              <p class="text-[11px] text-zinc-600 mt-0.5 truncate">{book.author}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Read -->
      <section id="read" class="mb-14 book-section">
        <div class="flex items-baseline gap-3 mb-5 sticky top-14 bg-[#09090B] py-2 z-10 border-b border-zinc-800 pb-3">
          <h2 class="text-2xl font-bold text-zinc-50">Read</h2>
          <span class="text-[12px] text-zinc-600 font-mono">{read.length} books</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-5">
          {read.map((book) => (
            <a
              href={book.link}
              target="_blank"
              rel="noopener noreferrer"
              class="book-card group block"
              data-title={book.title.toLowerCase()}
              data-author={book.author.toLowerCase()}
            >
              <div class="aspect-[2/3] rounded-md overflow-hidden bg-zinc-800 mb-2 shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300 relative">
                {book.cover ? (
                  <img src={book.cover} alt={book.title} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-zinc-600 text-xs px-2 text-center">{book.title}</div>
                )}
                {book.user_rating > 0 && (
                  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent px-2 pb-1.5 pt-4">
                    <div class="flex items-center gap-0.5">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <Star class={`w-2.5 h-2.5 ${i < book.user_rating ? 'text-amber-400 fill-amber-400' : 'text-zinc-600'}`} />
                      ))}
                    </div>
                  </div>
                )}
              </div>
              <p class="text-[12px] font-medium text-zinc-300 leading-tight line-clamp-2 group-hover:text-blue-400 transition-colors">{book.title}</p>
              <p class="text-[11px] text-zinc-600 mt-0.5 truncate">{book.author}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Want to Read -->
      <section id="want-to-read" class="mb-14 book-section">
        <div class="flex items-baseline gap-3 mb-5 sticky top-14 bg-[#09090B] py-2 z-10 border-b border-zinc-800 pb-3">
          <h2 class="text-2xl font-bold text-zinc-50">Want to Read</h2>
          <span class="text-[12px] text-zinc-600 font-mono">{wantToRead.length} books</span>
        </div>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 xl:grid-cols-7 gap-4">
          {wantToRead.map((book) => (
            <a
              href={book.link}
              target="_blank"
              rel="noopener noreferrer"
              class="book-card group block"
              data-title={book.title.toLowerCase()}
              data-author={book.author.toLowerCase()}
            >
              <div class="aspect-[2/3] rounded-md overflow-hidden bg-zinc-800 mb-1.5 shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300">
                {book.cover ? (
                  <img src={book.cover} alt={book.title} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-zinc-600 text-[10px] px-1 text-center">{book.title}</div>
                )}
              </div>
              <p class="text-[11px] font-medium text-zinc-300 leading-tight line-clamp-2 group-hover:text-blue-400 transition-colors">{book.title}</p>
              <p class="text-[10px] text-zinc-600 mt-0.5 truncate">{book.author}</p>
            </a>
          ))}
        </div>
      </section>

      <p id="no-results" class="hidden text-sm text-zinc-600 text-center py-8">No books match your search.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  const input = document.getElementById('book-search') as HTMLInputElement;
  const sections = document.querySelectorAll<HTMLElement>('.book-section');
  const noResults = document.getElementById('no-results')!;

  input.addEventListener('input', () => {
    const query = input.value.toLowerCase().trim();
    let visibleCount = 0;

    sections.forEach((section) => {
      let sectionVisible = false;
      section.querySelectorAll<HTMLElement>('.book-card').forEach((card) => {
        const title = card.dataset.title || '';
        const author = card.dataset.author || '';
        const visible = !query || title.includes(query) || author.includes(query);
        card.style.display = visible ? '' : 'none';
        if (visible) { sectionVisible = true; visibleCount++; }
      });
      section.classList.toggle('hidden', !sectionVisible);
    });

    noResults.classList.toggle('hidden', visibleCount > 0);
  });
</script>
