---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calendar from '@lucide/astro/icons/calendar';
import MapPin from '@lucide/astro/icons/map-pin';
import Video from '@lucide/astro/icons/video';
import Presentation from '@lucide/astro/icons/presentation';
import ExternalLink from '@lucide/astro/icons/external-link';
import Mic from '@lucide/astro/icons/mic';

interface Talk {
  title: string;
  event: string;
  eventUrl?: string;
  date: string;
  location: string;
  description: string;
  image?: string;
  sessionId?: string;
  videoUrl?: string;
  slidesUrl?: string;
  blogUrl?: string;
}

const upcoming: Talk[] = [
  {
    title: 'AIOps Revolution: How iHeart Slashed Incident Response Time by 60% with Bedrock',
    event: 'AWS re:Invent 2025',
    eventUrl: 'https://reinvent.awsevents.com/',
    date: 'December 1–5, 2025',
    location: 'Las Vegas, NV',
    sessionId: 'IND3327',
    image: '/images/reinvent-2025.jpeg',
    description: 'Learn how iHeartMedia leveraged Amazon Bedrock to build an AI-powered operations platform that cut incident response time by 60%. Co-presented with Sudipta Ghosh (AWS) and Harish Kumar Nagraj (iHeartMedia).',
  },
];

const pastTalks: Record<string, Talk[]> = {
};

const years = Object.keys(pastTalks).sort((a, b) => parseInt(b) - parseInt(a));
---

<BaseLayout title="Talks | Serkan Haytac">
  <section class="px-12 pt-12 pb-6">
    <h1 class="text-3xl font-bold text-zinc-50 tracking-tight" data-animate="fade-up">Talks</h1>
    <p class="text-zinc-500 text-sm mt-2" data-animate="fade-up" data-delay="0.1">Conference talks, meetups, and presentations.</p>
  </section>

  <!-- Upcoming talks -->
  {upcoming.length > 0 && (
    <section class="px-12 pb-8">
      <div class="flex items-center gap-2 mb-4" data-animate="fade-up" data-delay="0.15">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse-glow" />
        <h2 class="text-sm font-semibold text-green-400 uppercase tracking-wider">Next on Stage</h2>
      </div>
      <div data-stagger>
        {upcoming.map((talk) => (
          <article class="border border-green-900/50 bg-green-950/20 rounded-xl overflow-hidden mb-4 hover:border-green-800/50 transition-all duration-300">
            <div class="flex">
              {/* Image */}
              {talk.image && (
                <div class="w-72 shrink-0">
                  <img src={talk.image} alt={talk.title} class="w-full h-full object-cover" />
                </div>
              )}
              {/* Content */}
              <div class="flex-1 p-6">
                <div class="flex items-center gap-3 text-xs text-zinc-500 mb-3">
                  <span class="flex items-center gap-1">
                    <Calendar class="w-3 h-3" />
                    {talk.date}
                  </span>
                  <span class="flex items-center gap-1">
                    <MapPin class="w-3 h-3" />
                    {talk.location}
                  </span>
                  {talk.sessionId && (
                    <span class="px-2 py-0.5 rounded bg-zinc-800 text-[11px] font-mono font-medium text-zinc-400">
                      {talk.sessionId}
                    </span>
                  )}
                </div>
                <h3 class="text-lg font-semibold text-zinc-50 tracking-tight">{talk.title}</h3>
                {talk.eventUrl ? (
                  <a href={talk.eventUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-green-400 hover:text-green-300 transition-colors mt-1 inline-block">
                    {talk.event} →
                  </a>
                ) : (
                  <p class="text-sm text-green-400 mt-1">{talk.event}</p>
                )}
                <p class="text-[13px] text-zinc-400 leading-relaxed mt-3 max-w-2xl">{talk.description}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Past talks by year -->
  {years.map((year) => (
    <section class="px-12 pb-8">
      <h2 class="text-lg font-semibold text-zinc-50 mb-4 flex items-center gap-2" data-animate="fade-up">
        <Mic class="w-4 h-4 text-zinc-500" />
        {year}
      </h2>
      <div data-stagger>
        {pastTalks[year].map((talk) => (
          <article class="border border-zinc-800 rounded-xl p-6 mb-3 bg-zinc-900 hover:border-zinc-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-zinc-900/50 transition-all duration-300 ease-out group">
            <!-- Meta row -->
            <div class="flex items-center gap-3 text-xs text-zinc-500 mb-3">
              <span class="flex items-center gap-1">
                <Calendar class="w-3 h-3" />
                {talk.date}
              </span>
              <span class="flex items-center gap-1">
                <MapPin class="w-3 h-3" />
                {talk.location}
              </span>
              <span class="text-zinc-600">·</span>
              <span class="text-zinc-400 font-medium">{talk.event}</span>
            </div>

            <!-- Title -->
            <h3 class="text-base font-semibold text-zinc-50 tracking-tight group-hover:text-blue-400 transition-colors">
              {talk.title}
            </h3>

            <!-- Description -->
            <p class="text-[13px] text-zinc-500 leading-relaxed mt-2 max-w-2xl">
              {talk.description}
            </p>

            <!-- Resource links -->
            <div class="flex items-center gap-4 mt-4">
              {talk.videoUrl && (
                <a
                  href={talk.videoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 text-[13px] font-medium text-zinc-400 hover:text-zinc-50 transition-colors"
                >
                  <Video class="w-3.5 h-3.5" />
                  Watch
                </a>
              )}
              {talk.slidesUrl && (
                <a
                  href={talk.slidesUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 text-[13px] font-medium text-zinc-400 hover:text-zinc-50 transition-colors"
                >
                  <Presentation class="w-3.5 h-3.5" />
                  Slides
                </a>
              )}
              {talk.blogUrl && (
                <a
                  href={talk.blogUrl}
                  class="flex items-center gap-1.5 text-[13px] font-medium text-blue-500 hover:text-blue-400 transition-colors"
                >
                  <ExternalLink class="w-3.5 h-3.5" />
                  Blog Post
                </a>
              )}
              {talk.eventUrl && (
                <a
                  href={talk.eventUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 text-[13px] font-medium text-zinc-400 hover:text-zinc-50 transition-colors"
                >
                  <ExternalLink class="w-3.5 h-3.5" />
                  Event
                </a>
              )}
              {!talk.videoUrl && !talk.slidesUrl && !talk.blogUrl && !talk.eventUrl && (
                <span class="text-[12px] text-zinc-600 italic">Resources coming soon</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
