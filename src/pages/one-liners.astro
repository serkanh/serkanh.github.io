---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="One Liners | Serkan Haytac">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-zinc-50 tracking-tight">One Liners</h1>

    <div class="mt-8 space-y-8">
      <!-- RDS LatestRestorableTime -->
      <div>
        <p class="text-zinc-300 leading-relaxed">
          To get the <a href="https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/USER_PIT.html" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">LatestRestorableTime</a> on a given RDS instance:
        </p>
        <pre class="mt-3 bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto"><code class="text-[13px] font-mono text-zinc-300">aws rds describe-db-instances \
  --db-instance-identifier="evox-dev" \
  --query "DBInstances[*].[DBInstanceIdentifier,LatestRestorableTime]" --output text \
  | awk '&#123;print $2&#125;' | TZ='America/New_York' date</code></pre>
      </div>

      <hr class="border-t border-zinc-800" />

      <!-- Git fetch PR -->
      <div>
        <p class="text-zinc-300 leading-relaxed">
          To fetch the <code class="text-zinc-300 bg-zinc-800 px-1.5 py-0.5 rounded text-[13px] font-mono">PR #100</code> and create a local branch named <code class="text-zinc-300 bg-zinc-800 px-1.5 py-0.5 rounded text-[13px] font-mono">TICKET100</code> on local env:
        </p>
        <pre class="mt-3 bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto"><code class="text-[13px] font-mono text-zinc-300">git fetch upstream pull/100/head:TICKET100</code></pre>
      </div>

      <hr class="border-t border-zinc-800" />

      <!-- S3 copy with pattern -->
      <div>
        <p class="text-zinc-300 leading-relaxed">
          To copy S3 files matching a certain pattern to another location, excluding others. Use the optional <code class="text-zinc-300 bg-zinc-800 px-1.5 py-0.5 rounded text-[13px] font-mono">--dryrun</code> flag to verify the operation:
        </p>
        <pre class="mt-3 bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto"><code class="text-[13px] font-mono text-zinc-300">aws s3 cp s3://mybucket/reports/ s3://mybucket/reports/Archive/ \
  --dryrun --exclude "*" --include "VER_Daily_Report_2016*"</code></pre>
      </div>

      <hr class="border-t border-zinc-800" />

      <!-- Asciinema tmux -->
      <div>
        <p class="text-zinc-300 leading-relaxed">
          Record tmux session with <a href="https://asciinema.org/" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-400 transition">asciinema</a>:
        </p>
        <pre class="mt-3 bg-zinc-900 border border-zinc-800 rounded-lg p-4 overflow-x-auto"><code class="text-[13px] font-mono text-zinc-300">asciinema rec -c "tmux attach -t 1"</code></pre>
      </div>
    </div>
  </div>
</BaseLayout>
