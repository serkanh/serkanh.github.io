---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import ArrowLeft from '@lucide/astro/icons/arrow-left';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const allTags = [...new Set(posts.flatMap((p) => p.data.tags || []))];
  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`Posts tagged '${tag}' | Serkan Haytac`}>
  <div class="px-12 pt-12 pb-6">
    <a
      href="/tags"
      class="text-[13px] font-medium text-blue-500 hover:text-blue-400 transition flex items-center gap-1 mb-6"
    >
      <ArrowLeft class="w-3.5 h-3.5" />
      All tags
    </a>
    <h1 class="text-3xl font-bold text-zinc-50 tracking-tight">
      Posts tagged <span class="font-mono text-zinc-400">'{tag}'</span>
    </h1>
    <p class="text-zinc-500 text-sm mt-2">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  </div>

  <div class="px-12 pb-12 grid grid-cols-3 gap-4">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        description={post.data.description || (post.body ? post.body.slice(0, 150) + '...' : '')}
        tags={post.data.tags || []}
        slug={post.id}
      />
    ))}
  </div>
</BaseLayout>
