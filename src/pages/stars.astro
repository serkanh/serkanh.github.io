---
import BaseLayout from '../layouts/BaseLayout.astro';
import Star from '@lucide/astro/icons/star';
import Github from '@lucide/astro/icons/github';

/*──────────────────────────────────────────────
  Read starred repos from pre-built JSON
  Generated by: node scripts/fetch-stars.mjs
──────────────────────────────────────────────*/

import starsData from '../data/stars.json';

interface StarredRepo {
  full_name: string;
  html_url: string;
  description: string | null;
  stargazers_count: number;
  language: string | null;
  topics: string[];
  starred_at: string;
}

const allRepos: StarredRepo[] = starsData as StarredRepo[];

// ── Group by year (most recent first) ──
const byYear: Record<string, StarredRepo[]> = {};
for (const repo of allRepos) {
  const year = new Date(repo.starred_at).getFullYear().toString();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(repo);
}
const years = Object.keys(byYear).sort((a, b) => parseInt(b) - parseInt(a));
for (const year of years) {
  byYear[year].sort((a, b) => new Date(b.starred_at).getTime() - new Date(a.starred_at).getTime());
}

// ── Group by topic ──
const NOISE_TOPICS = new Set(['hacktoberfest']);
const byTopic: Record<string, StarredRepo[]> = {};
const untagged: StarredRepo[] = [];

for (const repo of allRepos) {
  const validTopics = (repo.topics || []).filter((t) => !NOISE_TOPICS.has(t));
  if (validTopics.length === 0) {
    untagged.push(repo);
  } else {
    for (const topic of validTopics) {
      if (!byTopic[topic]) byTopic[topic] = [];
      byTopic[topic].push(repo);
    }
  }
}

// Sort topics by count desc, then alphabetically
const topicEntries = Object.entries(byTopic).sort((a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]));
const topicNames = topicEntries.map(([name]) => name);

// Sort repos within each topic by stars desc
for (const [, repos] of topicEntries) {
  repos.sort((a, b) => b.stargazers_count - a.stargazers_count);
}
untagged.sort((a, b) => b.stargazers_count - a.stargazers_count);

// ── Group by language ──
const byLang: Record<string, StarredRepo[]> = {};
for (const repo of allRepos) {
  const lang = repo.language || 'Other';
  if (!byLang[lang]) byLang[lang] = [];
  byLang[lang].push(repo);
}
const langEntries = Object.entries(byLang).sort((a, b) => b[1].length - a[1].length);
for (const [, repos] of langEntries) {
  repos.sort((a, b) => b.stargazers_count - a.stargazers_count);
}

// Language stats for sidebar
const langCounts: Record<string, number> = {};
for (const repo of allRepos) {
  const lang = repo.language || 'Other';
  langCounts[lang] = (langCounts[lang] || 0) + 1;
}
const languages = Object.entries(langCounts).sort((a, b) => b[1] - a[1]);

const languageColors: Record<string, string> = {
  Python: '#3572A5',
  TypeScript: '#3178c6',
  JavaScript: '#f1e05a',
  Go: '#00ADD8',
  Rust: '#dea584',
  Shell: '#89e051',
  Ruby: '#701516',
  Swift: '#F05138',
  'C++': '#f34b7d',
  C: '#555555',
  Java: '#b07219',
  HCL: '#844FBA',
  Nim: '#ffc200',
  Crystal: '#000100',
  Makefile: '#427819',
  MDX: '#fcb32c',
  Other: '#6B7280',
};

function formatStars(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return n.toString();
}

const SIDEBAR_TOPIC_LIMIT = 30;
---

<BaseLayout title="Stars | Serkan Haytac">
  <div class="flex">
    <!-- Sidebar -->
    <aside class="hidden lg:block w-56 shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto border-r border-zinc-800 px-6 py-10">
      <!-- View mode switcher -->
      <div class="flex rounded-lg bg-zinc-900 border border-zinc-800 p-0.5 mb-6">
        <button data-view="year" class="view-btn flex-1 text-[11px] font-semibold py-1.5 rounded-md text-zinc-50 bg-zinc-800 transition-colors">Year</button>
        <button data-view="topics" class="view-btn flex-1 text-[11px] font-semibold py-1.5 rounded-md text-zinc-500 hover:text-zinc-300 transition-colors">Topics</button>
        <button data-view="language" class="view-btn flex-1 text-[11px] font-semibold py-1.5 rounded-md text-zinc-500 hover:text-zinc-300 transition-colors">Lang</button>
      </div>

      <!-- Year sidebar -->
      <div id="sidebar-year">
        <p class="text-[11px] font-semibold text-zinc-500 uppercase tracking-widest mb-3">Years</p>
        <nav class="space-y-1 mb-8">
          {years.map((year) => (
            <a href={`#year-${year}`} class="flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-400 hover:text-zinc-50 hover:bg-zinc-800/50 transition-colors">
              <span class="font-medium">{year}</span>
              <span class="text-[11px] text-zinc-600 font-mono">{byYear[year].length}</span>
            </a>
          ))}
        </nav>

        <p class="text-[11px] font-semibold text-zinc-500 uppercase tracking-widest mb-3">Filter by language</p>
        <nav class="space-y-1">
          <button data-lang-filter="all" class="lang-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-50 bg-zinc-800 transition-colors">
            <span>All</span>
            <span class="text-[11px] text-zinc-500 font-mono">{allRepos.length}</span>
          </button>
          {languages.map(([lang, count]) => (
            <button data-lang-filter={lang} class="lang-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-400 hover:bg-zinc-800/50 transition-colors">
              <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${languageColors[lang] || '#6B7280'}`} />
                {lang}
              </span>
              <span class="text-[11px] text-zinc-600 font-mono">{count}</span>
            </button>
          ))}
        </nav>
      </div>

      <!-- Topics sidebar -->
      <div id="sidebar-topics" class="hidden">
        <p class="text-[11px] font-semibold text-zinc-500 uppercase tracking-widest mb-3">Topics</p>
        <nav class="space-y-1">
          <button data-topic-filter="all" class="topic-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-50 bg-zinc-800 transition-colors">
            <span>All</span>
            <span class="text-[11px] text-zinc-500 font-mono">{allRepos.length}</span>
          </button>
          {topicEntries.slice(0, SIDEBAR_TOPIC_LIMIT).map(([topic, repos]) => (
            <button data-topic-filter={topic} class="topic-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-400 hover:bg-zinc-800/50 transition-colors">
              <span class="truncate">{topic}</span>
              <span class="text-[11px] text-zinc-600 font-mono shrink-0 ml-2">{repos.length}</span>
            </button>
          ))}
          {topicEntries.length > SIDEBAR_TOPIC_LIMIT && (
            <button id="show-more-topics" class="w-full text-left px-2 py-1.5 text-[12px] text-zinc-600 hover:text-zinc-400 transition-colors">
              + {topicEntries.length - SIDEBAR_TOPIC_LIMIT} more...
            </button>
          )}
          <div id="extra-topics" class="hidden space-y-1">
            {topicEntries.slice(SIDEBAR_TOPIC_LIMIT).map(([topic, repos]) => (
              <button data-topic-filter={topic} class="topic-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-400 hover:bg-zinc-800/50 transition-colors">
                <span class="truncate">{topic}</span>
                <span class="text-[11px] text-zinc-600 font-mono shrink-0 ml-2">{repos.length}</span>
              </button>
            ))}
          </div>
        </nav>
      </div>

      <!-- Language sidebar -->
      <div id="sidebar-language" class="hidden">
        <p class="text-[11px] font-semibold text-zinc-500 uppercase tracking-widest mb-3">Languages</p>
        <nav class="space-y-1">
          <button data-langview-filter="all" class="langview-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-50 bg-zinc-800 transition-colors">
            <span>All</span>
            <span class="text-[11px] text-zinc-500 font-mono">{allRepos.length}</span>
          </button>
          {languages.map(([lang, count]) => (
            <button data-langview-filter={lang} class="langview-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-md text-[13px] text-zinc-400 hover:bg-zinc-800/50 transition-colors">
              <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${languageColors[lang] || '#6B7280'}`} />
                {lang}
              </span>
              <span class="text-[11px] text-zinc-600 font-mono">{count}</span>
            </button>
          ))}
        </nav>
      </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 min-w-0 px-8 lg:px-12 pt-12 pb-16">
      <h1 class="text-3xl font-bold text-zinc-50 tracking-tight" data-animate="fade-up">
        <span class="inline-flex items-center gap-3">
          <Github class="w-8 h-8" />
          Starred Repos
        </span>
      </h1>
      <p id="subtitle" class="text-zinc-500 text-sm mt-2" data-animate="fade-up" data-delay="0.1">
        {allRepos.length} repos I've starred on GitHub, sorted by when I discovered them.
      </p>

      <!-- Mobile view switcher -->
      <div class="flex lg:hidden rounded-lg bg-zinc-900 border border-zinc-800 p-0.5 mt-4" data-animate="fade-up" data-delay="0.12">
        <button data-view="year" class="view-btn flex-1 text-[12px] font-semibold py-2 rounded-md text-zinc-50 bg-zinc-800 transition-colors">Year</button>
        <button data-view="topics" class="view-btn flex-1 text-[12px] font-semibold py-2 rounded-md text-zinc-500 hover:text-zinc-300 transition-colors">Topics</button>
        <button data-view="language" class="view-btn flex-1 text-[12px] font-semibold py-2 rounded-md text-zinc-500 hover:text-zinc-300 transition-colors">Lang</button>
      </div>

      <!-- Search -->
      <div class="mt-6 mb-10" data-animate="fade-up" data-delay="0.15">
        <input
          id="star-search"
          type="text"
          placeholder="Filter starred repos..."
          class="w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-50 placeholder-zinc-600 outline-none focus:border-zinc-600 transition-colors"
        />
      </div>

      <!-- ═══ YEAR VIEW ═══ -->
      <div id="view-year">
        {years.map((year) => (
          <section id={`year-${year}`} class="mb-12 year-section" data-year={year}>
            <div class="flex items-baseline gap-3 mb-5 sticky top-14 bg-[#09090B] py-2 z-10 border-b border-zinc-800 pb-3">
              <h2 class="text-2xl font-bold text-zinc-50">{year}</h2>
              <span class="text-[12px] text-zinc-600 font-mono">{byYear[year].length} repos</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
              {byYear[year].map((repo) => (
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="star-card group border border-zinc-800 rounded-lg p-4 bg-zinc-900 hover:border-zinc-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-zinc-950/50 transition-all duration-300 ease-out block"
                  data-name={repo.full_name.toLowerCase()}
                  data-desc={(repo.description || '').toLowerCase()}
                  data-topics={(repo.topics || []).join(' ').toLowerCase()}
                  data-lang={repo.language || 'Other'}
                >
                  <div class="flex items-start justify-between gap-2">
                    <p class="text-[13px] font-semibold text-zinc-200 group-hover:text-blue-400 transition-colors truncate">
                      {repo.full_name.split('/')[1]}
                    </p>
                    <div class="flex items-center gap-1 text-zinc-600 shrink-0">
                      <Star class="w-3 h-3" />
                      <span class="text-[11px] font-mono">{formatStars(repo.stargazers_count)}</span>
                    </div>
                  </div>
                  <div class="flex items-center justify-between mt-0.5">
                    <div class="flex items-center gap-2 min-w-0">
                      <p class="text-[11px] text-zinc-600 font-mono truncate">{repo.full_name.split('/')[0]}</p>
                      {repo.language && (
                        <span class="flex items-center gap-1 shrink-0">
                          <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${languageColors[repo.language] || '#6B7280'}`} />
                          <span class="text-[10px] text-zinc-600">{repo.language}</span>
                        </span>
                      )}
                    </div>
                    <span class="text-[10px] text-zinc-700 font-mono shrink-0">{new Date(repo.starred_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                  </div>
                  {repo.description && (
                    <p class="text-[12px] text-zinc-500 leading-relaxed mt-2 line-clamp-2">
                      {repo.description}
                    </p>
                  )}
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- ═══ TOPICS VIEW ═══ -->
      <div id="view-topics" class="hidden">
        {topicEntries.map(([topic, repos]) => (
          <section class="mb-12 topic-section" data-topic={topic}>
            <div class="flex items-baseline gap-3 mb-5 sticky top-14 bg-[#09090B] py-2 z-10 border-b border-zinc-800 pb-3">
              <h2 class="text-2xl font-bold text-zinc-50">{topic}</h2>
              <span class="text-[12px] text-zinc-600 font-mono">{repos.length} repos</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
              {repos.map((repo) => (
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="star-card group border border-zinc-800 rounded-lg p-4 bg-zinc-900 hover:border-zinc-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-zinc-950/50 transition-all duration-300 ease-out block"
                  data-name={repo.full_name.toLowerCase()}
                  data-desc={(repo.description || '').toLowerCase()}
                  data-topics={(repo.topics || []).join(' ').toLowerCase()}
                  data-lang={repo.language || 'Other'}
                >
                  <div class="flex items-start justify-between gap-2">
                    <p class="text-[13px] font-semibold text-zinc-200 group-hover:text-blue-400 transition-colors truncate">
                      {repo.full_name.split('/')[1]}
                    </p>
                    <div class="flex items-center gap-1 text-zinc-600 shrink-0">
                      <Star class="w-3 h-3" />
                      <span class="text-[11px] font-mono">{formatStars(repo.stargazers_count)}</span>
                    </div>
                  </div>
                  <div class="flex items-center justify-between mt-0.5">
                    <div class="flex items-center gap-2 min-w-0">
                      <p class="text-[11px] text-zinc-600 font-mono truncate">{repo.full_name.split('/')[0]}</p>
                      {repo.language && (
                        <span class="flex items-center gap-1 shrink-0">
                          <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${languageColors[repo.language] || '#6B7280'}`} />
                          <span class="text-[10px] text-zinc-600">{repo.language}</span>
                        </span>
                      )}
                    </div>
                    <span class="text-[10px] text-zinc-700 font-mono shrink-0">{new Date(repo.starred_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                  {repo.description && (
                    <p class="text-[12px] text-zinc-500 leading-relaxed mt-2 line-clamp-2">
                      {repo.description}
                    </p>
                  )}
                </a>
              ))}
            </div>
          </section>
        ))}
        {untagged.length > 0 && (
          <section class="mb-12 topic-section" data-topic="Untagged">
            <div class="flex items-baseline gap-3 mb-5 sticky top-14 bg-[#09090B] py-2 z-10 border-b border-zinc-800 pb-3">
              <h2 class="text-2xl font-bold text-zinc-500">Untagged</h2>
              <span class="text-[12px] text-zinc-600 font-mono">{untagged.length} repos</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
              {untagged.map((repo) => (
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="star-card group border border-zinc-800 rounded-lg p-4 bg-zinc-900 hover:border-zinc-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-zinc-950/50 transition-all duration-300 ease-out block"
                  data-name={repo.full_name.toLowerCase()}
                  data-desc={(repo.description || '').toLowerCase()}
                  data-topics=""
                  data-lang={repo.language || 'Other'}
                >
                  <div class="flex items-start justify-between gap-2">
                    <p class="text-[13px] font-semibold text-zinc-200 group-hover:text-blue-400 transition-colors truncate">
                      {repo.full_name.split('/')[1]}
                    </p>
                    <div class="flex items-center gap-1 text-zinc-600 shrink-0">
                      <Star class="w-3 h-3" />
                      <span class="text-[11px] font-mono">{formatStars(repo.stargazers_count)}</span>
                    </div>
                  </div>
                  <div class="flex items-center justify-between mt-0.5">
                    <div class="flex items-center gap-2 min-w-0">
                      <p class="text-[11px] text-zinc-600 font-mono truncate">{repo.full_name.split('/')[0]}</p>
                      {repo.language && (
                        <span class="flex items-center gap-1 shrink-0">
                          <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${languageColors[repo.language] || '#6B7280'}`} />
                          <span class="text-[10px] text-zinc-600">{repo.language}</span>
                        </span>
                      )}
                    </div>
                    <span class="text-[10px] text-zinc-700 font-mono shrink-0">{new Date(repo.starred_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                  {repo.description && (
                    <p class="text-[12px] text-zinc-500 leading-relaxed mt-2 line-clamp-2">
                      {repo.description}
                    </p>
                  )}
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- ═══ LANGUAGE VIEW ═══ -->
      <div id="view-language" class="hidden">
        {langEntries.map(([lang, repos]) => (
          <section class="mb-12 lang-section" data-langgroup={lang}>
            <div class="flex items-baseline gap-3 mb-5 sticky top-14 bg-[#09090B] py-2 z-10 border-b border-zinc-800 pb-3">
              <span class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full" style={`background-color: ${languageColors[lang] || '#6B7280'}`} />
                <h2 class="text-2xl font-bold text-zinc-50">{lang}</h2>
              </span>
              <span class="text-[12px] text-zinc-600 font-mono">{repos.length} repos</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
              {repos.map((repo) => (
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="star-card group border border-zinc-800 rounded-lg p-4 bg-zinc-900 hover:border-zinc-700 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-zinc-950/50 transition-all duration-300 ease-out block"
                  data-name={repo.full_name.toLowerCase()}
                  data-desc={(repo.description || '').toLowerCase()}
                  data-topics={(repo.topics || []).join(' ').toLowerCase()}
                  data-lang={repo.language || 'Other'}
                >
                  <div class="flex items-start justify-between gap-2">
                    <p class="text-[13px] font-semibold text-zinc-200 group-hover:text-blue-400 transition-colors truncate">
                      {repo.full_name.split('/')[1]}
                    </p>
                    <div class="flex items-center gap-1 text-zinc-600 shrink-0">
                      <Star class="w-3 h-3" />
                      <span class="text-[11px] font-mono">{formatStars(repo.stargazers_count)}</span>
                    </div>
                  </div>
                  <div class="flex items-center justify-between mt-0.5">
                    <div class="flex items-center gap-2 min-w-0">
                      <p class="text-[11px] text-zinc-600 font-mono truncate">{repo.full_name.split('/')[0]}</p>
                    </div>
                    <span class="text-[10px] text-zinc-700 font-mono shrink-0">{new Date(repo.starred_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                  {repo.description && (
                    <p class="text-[12px] text-zinc-500 leading-relaxed mt-2 line-clamp-2">
                      {repo.description}
                    </p>
                  )}
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      <p id="no-results" class="hidden text-sm text-zinc-600 text-center py-8">No repos match your search.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  const input = document.getElementById('star-search') as HTMLInputElement;
  const noResults = document.getElementById('no-results')!;
  const subtitle = document.getElementById('subtitle')!;

  // View containers
  const viewYear = document.getElementById('view-year')!;
  const viewTopics = document.getElementById('view-topics')!;
  const viewLanguage = document.getElementById('view-language')!;
  const views: Record<string, HTMLElement> = { year: viewYear, topics: viewTopics, language: viewLanguage };

  // Sidebars
  const sidebarYear = document.getElementById('sidebar-year')!;
  const sidebarTopics = document.getElementById('sidebar-topics')!;
  const sidebarLanguage = document.getElementById('sidebar-language')!;
  const sidebars: Record<string, HTMLElement> = { year: sidebarYear, topics: sidebarTopics, language: sidebarLanguage };

  // View switcher buttons (both desktop sidebar + mobile)
  const viewBtns = document.querySelectorAll<HTMLButtonElement>('.view-btn');

  // Filter buttons
  const langBtns = document.querySelectorAll<HTMLButtonElement>('.lang-btn');
  const topicBtns = document.querySelectorAll<HTMLButtonElement>('.topic-btn');
  const langviewBtns = document.querySelectorAll<HTMLButtonElement>('.langview-btn');

  // Show more topics
  const showMoreBtn = document.getElementById('show-more-topics');
  const extraTopics = document.getElementById('extra-topics');
  if (showMoreBtn && extraTopics) {
    showMoreBtn.addEventListener('click', () => {
      extraTopics.classList.remove('hidden');
      showMoreBtn.classList.add('hidden');
    });
  }

  let activeView = 'year';
  let activeLang = 'all';       // year view lang filter
  let activeTopic = 'all';      // topics view filter
  let activeLangView = 'all';   // language view filter

  const subtitles: Record<string, string> = {
    year: `${document.querySelectorAll('#view-year .star-card').length} repos I've starred on GitHub, sorted by when I discovered them.`,
    topics: `Browse starred repos by topic — repos appear under every topic they belong to.`,
    language: `Starred repos grouped by primary language.`,
  };

  function switchView(view: string) {
    activeView = view;

    // Toggle view containers
    for (const [key, el] of Object.entries(views)) {
      el.classList.toggle('hidden', key !== view);
    }
    // Toggle sidebars
    for (const [key, el] of Object.entries(sidebars)) {
      el.classList.toggle('hidden', key !== view);
    }
    // Update all view buttons (desktop + mobile)
    viewBtns.forEach((btn) => {
      const isActive = btn.dataset.view === view;
      btn.classList.toggle('text-zinc-50', isActive);
      btn.classList.toggle('bg-zinc-800', isActive);
      btn.classList.toggle('text-zinc-500', !isActive);
    });

    subtitle.textContent = subtitles[view] || '';

    // Reset filters when switching
    activeLang = 'all';
    activeTopic = 'all';
    activeLangView = 'all';
    resetFilterButtons(langBtns, 'langFilter');
    resetFilterButtons(topicBtns, 'topicFilter');
    resetFilterButtons(langviewBtns, 'langviewFilter');

    applyFilters();
  }

  function resetFilterButtons(btns: NodeListOf<HTMLButtonElement>, dataKey: string) {
    btns.forEach((b) => {
      const isAll = (b.dataset as any)[dataKey] === 'all';
      b.classList.toggle('text-zinc-50', isAll);
      b.classList.toggle('bg-zinc-800', isAll);
      b.classList.toggle('text-zinc-400', !isAll);
    });
  }

  function applyFilters() {
    const query = input.value.toLowerCase().trim();
    let visibleCount = 0;

    if (activeView === 'year') {
      viewYear.querySelectorAll<HTMLElement>('.year-section').forEach((section) => {
        let sectionVisible = false;
        section.querySelectorAll<HTMLElement>('.star-card').forEach((card) => {
          const visible = matchCard(card, query) && (activeLang === 'all' || card.dataset.lang === activeLang);
          card.style.display = visible ? '' : 'none';
          if (visible) { sectionVisible = true; visibleCount++; }
        });
        section.classList.toggle('hidden', !sectionVisible);
      });
    } else if (activeView === 'topics') {
      viewTopics.querySelectorAll<HTMLElement>('.topic-section').forEach((section) => {
        const sectionTopic = section.dataset.topic || '';
        const topicMatch = activeTopic === 'all' || sectionTopic === activeTopic;
        if (!topicMatch) {
          section.classList.add('hidden');
          return;
        }
        let sectionVisible = false;
        section.querySelectorAll<HTMLElement>('.star-card').forEach((card) => {
          const visible = matchCard(card, query);
          card.style.display = visible ? '' : 'none';
          if (visible) { sectionVisible = true; visibleCount++; }
        });
        section.classList.toggle('hidden', !sectionVisible);
      });
    } else if (activeView === 'language') {
      viewLanguage.querySelectorAll<HTMLElement>('.lang-section').forEach((section) => {
        const sectionLang = section.dataset.langgroup || '';
        const langMatch = activeLangView === 'all' || sectionLang === activeLangView;
        if (!langMatch) {
          section.classList.add('hidden');
          return;
        }
        let sectionVisible = false;
        section.querySelectorAll<HTMLElement>('.star-card').forEach((card) => {
          const visible = matchCard(card, query);
          card.style.display = visible ? '' : 'none';
          if (visible) { sectionVisible = true; visibleCount++; }
        });
        section.classList.toggle('hidden', !sectionVisible);
      });
    }

    noResults.classList.toggle('hidden', visibleCount > 0);
  }

  function matchCard(card: HTMLElement, query: string): boolean {
    if (!query) return true;
    const name = card.dataset.name || '';
    const desc = card.dataset.desc || '';
    const topics = card.dataset.topics || '';
    return name.includes(query) || desc.includes(query) || topics.includes(query);
  }

  // Event listeners
  input.addEventListener('input', applyFilters);

  viewBtns.forEach((btn) => {
    btn.addEventListener('click', () => switchView(btn.dataset.view!));
  });

  langBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeLang = btn.dataset.langFilter!;
      setActive(langBtns, btn);
      applyFilters();
    });
  });

  topicBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeTopic = btn.dataset.topicFilter!;
      setActive(topicBtns, btn);
      applyFilters();
    });
  });

  langviewBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeLangView = btn.dataset.langviewFilter!;
      setActive(langviewBtns, btn);
      applyFilters();
    });
  });

  function setActive(btns: NodeListOf<HTMLButtonElement>, active: HTMLButtonElement) {
    btns.forEach((b) => {
      b.classList.remove('text-zinc-50', 'bg-zinc-800');
      b.classList.add('text-zinc-400');
    });
    active.classList.add('text-zinc-50', 'bg-zinc-800');
    active.classList.remove('text-zinc-400');
  }
</script>
